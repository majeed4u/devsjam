///////////////////////////
// TAG (Many-to-Many)
///////////////////////////

model Tag {
    id   String @id @default(cuid())
    name String
    slug String @unique

    posts PostTag[]

    createdAt DateTime @default(now())

    // Performance indexes
    @@index([name]) // For searching tags by name
    @@index([slug]) // For searching tags by slug
}

///////////////////////////
// POST TAGS (Many-to-Many)
///////////////////////////

model PostTag {
    postId String
    tagId  String

    post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
    tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@id([postId, tagId])
    // Additional indexes for many-to-many queries
    @@index([tagId]) // For finding posts by tag
}
